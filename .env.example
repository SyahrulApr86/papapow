# Neon: use pooled URL for DATABASE_URL, direct URL for DIRECT_URL
DATABASE_URL=postgres://papapow:papapow@localhost:55432/papapow
DIRECT_URL=postgres://papapow:papapow@localhost:55432/papapow
ADMIN_PASSWORD=change-this-password
ADMIN_SESSION_SECRET=change-this-secret
USER_SESSION_SECRET=change-this-user-secret
NEXT_PUBLIC_WA_NUMBER=6281234567890

# Object Storage (MinIO for dev, R2 for prod)
# Dev (MinIO via docker compose):
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY_ID=papapow
STORAGE_SECRET_ACCESS_KEY=papapow123
STORAGE_BUCKET=papapow
STORAGE_PUBLIC_URL=http://localhost:9000/papapow
STORAGE_FORCE_PATH_STYLE=true

# Prod (Cloudflare R2) — uncomment and fill in:
# STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=<r2-access-key-id>
# STORAGE_SECRET_ACCESS_KEY=<r2-secret-access-key>
# STORAGE_BUCKET=papapow
# STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev
# STORAGE_FORCE_PATH_STYLE=false
